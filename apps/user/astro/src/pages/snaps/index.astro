---
export const prerender = false; // 서버 렌더 (작품 목록을 요청 시 API 로 가져옴)

import AppShellLayout from '@/layouts/AppShellLayout.astro';
import { ArtworkCard } from '@dearbloom/ui';
import { getArtworks, regionLabel, type ArtworkListItem } from '@dearbloom/shared';

const token = Astro.cookies.get('accessToken')?.value;
// 로그인 시 저장상태(isSaved)를 반영 → per-user 렌더(공유 캐시 금지). 비로그인은 캐시 가능(SEO).
if (token) Astro.response.headers.set('Cache-Control', 'private, no-store');

let artworks: ArtworkListItem[] = [];
let loadFailed = false;
try {
  artworks = await getArtworks(token ? { token } : undefined);
} catch {
  loadFailed = true;
}
---

<AppShellLayout title="작품 탐색" navVariant="light">
  <div class="mx-auto max-w-md">
    {/* 상단 앱바 */}
    <header class="flex h-12 items-center justify-between px-4">
      <span class="flex items-center gap-1 text-head-1 font-semibold text-primary">
        DearBloom
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden>
          <circle cx="8.5" cy="8.5" r="3.8" /><circle cx="15.5" cy="8.5" r="3.8" /><circle cx="8.5" cy="15.5" r="3.8" /><circle cx="15.5" cy="15.5" r="3.8" /><path d="M12 12l-1.4 8h2.8z" />
        </svg>
      </span>
    </header>

    {!loadFailed && artworks.length > 0 && (
      <div class="px-4 pb-3 pt-3">
        <span class="text-caption-1 text-neutral-600">전체 {artworks.length}</span>
      </div>
    )}

    {/* 작품 피드 */}
    {loadFailed ? (
      <p class="px-4 py-16 text-center text-body-4 text-neutral-500">작품을 불러오지 못했어요. 잠시 후 다시 시도해주세요.</p>
    ) : artworks.length === 0 ? (
      <p class="px-4 py-16 text-center text-body-4 text-neutral-500">아직 등록된 작품이 없어요.</p>
    ) : (
      <div class="grid grid-cols-2 gap-x-3 gap-y-5 px-4 pb-6">
        {artworks.map((a) => (
          <ArtworkCard
            artworkId={a.artworkId}
            title={a.title}
            artistNickname={a.artistNickname}
            price={a.price}
            thumbnailUrl={a.thumbnailUrl}
            regions={a.artistRegionList?.map(regionLabel)}
            initialSaved={!!a.isSaved}
            client:load
          />
        ))}
      </div>
    )}
  </div>
</AppShellLayout>
