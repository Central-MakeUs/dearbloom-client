---
export const prerender = false; // 서버 렌더 (작품 상세를 요청 시 API 로 가져옴)

import { SaveHeart } from '@dearbloom/ui';
import { getArtwork, regionLabels, type ArtworkDetail } from '@dearbloom/shared';

const { slug } = Astro.params;
const token = Astro.cookies.get('accessToken')?.value;

// 로그인별 isSaved 가 담기므로 CDN 공유 캐시 금지(익명 렌더가 로그인 사용자에게 새는 것 방지).
Astro.response.headers.set('Cache-Control', 'private, no-store');

let artwork: ArtworkDetail | null = null;
try {
  artwork = await getArtwork(slug!, token ? { token } : undefined);
} catch {
  artwork = null;
}

const won = (n: number) => `${n.toLocaleString()}원`;
const photos = artwork ? [...artwork.photoList].sort((a, b) => a.sortOrder - b.sortOrder) : [];

// 촬영 장소: schoolNameList 우선, 없으면 사진의 대학명에서 도출
const shootPlaces = artwork
  ? artwork.schoolNameList?.length
    ? artwork.schoolNameList
    : [...new Set(photos.map((p) => p.universityName).filter(Boolean))]
  : [];

// 인원 라벨 (min~max)
const headCountLabel = artwork
  ? artwork.minHeadCount === artwork.maxHeadCount
    ? `${artwork.minHeadCount}인`
    : `${artwork.minHeadCount}~${artwork.maxHeadCount}인`
  : '';
const packages = artwork?.packageList ?? [];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{artwork?.title ?? '작품'} · dearBloom</title>
  </head>
  <body class="min-h-screen bg-neutral-100 font-sans text-neutral-950">
    {
      !artwork ? (
        <div class="flex min-h-screen flex-col items-center justify-center gap-4 px-6 text-center">
          <p class="text-body-4 text-neutral-600">작품을 찾을 수 없어요.</p>
          <a href="/snaps" class="rounded-md bg-primary px-5 py-2.5 text-body-5 text-neutral-0">작품 탐색으로</a>
        </div>
      ) : (
        <>
          {/* Header */}
          <header class="sticky top-0 z-20 flex h-[52px] items-center justify-between bg-neutral-0 px-2">
            <a href="/snaps" aria-label="뒤로가기" class="flex h-11 w-11 items-center justify-center text-neutral-950">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden><path d="m15 18-6-6 6-6" /></svg>
            </a>
            <h1 class="truncate text-head-3 text-neutral-950">작품 상세</h1>
            <div class="flex items-center">
              <div class="flex h-11 w-11 items-center justify-center">
                <SaveHeart artworkId={artwork.artworkId} initialSaved={!!artwork.isSaved} size={24} client:load />
              </div>
              <button id="share-btn" type="button" aria-label="공유" class="flex h-11 w-11 items-center justify-center text-neutral-950">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
                  <path d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7" />
                  <path d="M16 6l-4-4-4 4" />
                  <path d="M12 2v13" />
                </svg>
              </button>
            </div>
          </header>

          {/* 상단 화이트 블록: 캐러셀 + 제목 + 탭 */}
          <div class="bg-neutral-0">
            {photos.length > 0 && (
              <div class="flex snap-x gap-1 overflow-x-auto px-2 pb-2">
                {photos.map((p) =>
                  p.fileType === 'VIDEO' ? (
                    <video src={p.fileUrl} class="aspect-[3/4] w-[190px] shrink-0 snap-start rounded-sm object-cover" controls />
                  ) : (
                    <img src={p.fileUrl} alt={artwork.title} loading="lazy" class="aspect-[3/4] w-[190px] shrink-0 snap-start rounded-sm object-cover" />
                  ),
                )}
              </div>
            )}

            {/* 제목 + 지역칩 + 작가 */}
            <div class="px-4 pt-3">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <h2 class="text-head-2 text-neutral-950">{artwork.title}</h2>
                {artwork.artist.regionList?.length > 0 && (
                  <span class="rounded-sm bg-neutral-200 px-2 py-1 text-body-5 text-neutral-700">{regionLabels(artwork.artist.regionList)}</span>
                )}
              </div>
              <p class="mt-1 text-body-5 text-neutral-800">{artwork.artist.nickname}</p>
            </div>

            {/* 인페이지 탭 (리뷰는 준비중) */}
            <div class="mt-3 flex border-b border-neutral-200">
              <span class="flex-1 border-b-2 border-primary py-3 text-center text-head-3 text-primary">작품정보</span>
              <span class="flex-1 py-3 text-center text-body-1 text-neutral-400">리뷰</span>
            </div>
          </div>

          <div class="pb-28 pt-4">
            {/* 촬영 정보 (인원 / 촬영 장소) */}
            <section class="mb-3">
              <h3 class="mb-2 px-4 text-head-3 text-neutral-800">촬영 정보</h3>
              <div class="mx-4 rounded-lg bg-neutral-0 p-4">
                <dl class="flex flex-col gap-3">
                  <div class="flex items-start justify-between gap-4">
                    <dt class="shrink-0 text-body-6 text-neutral-600">인원</dt>
                    <dd class="text-right text-body-4 text-neutral-950">{headCountLabel}</dd>
                  </div>
                  {shootPlaces.length > 0 && (
                    <div class="flex items-start justify-between gap-4">
                      <dt class="shrink-0 text-body-6 text-neutral-600">촬영 장소</dt>
                      <dd class="text-right text-body-4 text-neutral-950">{shootPlaces.join(', ')}</dd>
                    </div>
                  )}
                </dl>
              </div>
            </section>

            {/* 촬영 구성 (패키지 목록) */}
            {packages.length > 0 && (
              <section class="mb-3">
                <h3 class="mb-2 px-4 text-head-3 text-neutral-800">촬영 구성</h3>
                <div class="mx-4 flex flex-col gap-2">
                  {packages.map((pkg) => (
                    <div class="rounded-lg bg-neutral-0 p-4">
                      <div class="flex items-start justify-between gap-4">
                        <span class="text-body-4 text-neutral-950">{pkg.packageName}</span>
                        <span class="shrink-0 text-body-3 text-primary">{won(pkg.price)}</span>
                      </div>
                      <div class="mt-1 flex flex-wrap gap-x-3 text-body-6 text-neutral-600">
                        {pkg.durationMinutes ? <span>{pkg.durationMinutes}분</span> : null}
                        {pkg.finalPhotoCount ? <span>보정 {pkg.finalPhotoCount}장</span> : null}
                      </div>
                      {pkg.extraInfo && (
                        <p class="mt-2 whitespace-pre-line border-t border-neutral-200 pt-2 text-body-6 text-neutral-800">{pkg.extraInfo}</p>
                      )}
                    </div>
                  ))}
                </div>
              </section>
            )}

            {/* 이 작가의 다른 작품 */}
            {artwork.otherArtworkList?.length > 0 && (
              <section class="mb-3">
                <h3 class="mb-3 px-4 text-head-3 text-neutral-800">이 작가의 다른 작품</h3>
                <div class="grid grid-cols-3 gap-2 px-4">
                  {artwork.otherArtworkList.map((o) => (
                    <a href={`/snaps/${o.artworkId}`} class="block aspect-[4/5] overflow-hidden rounded-md bg-neutral-300">
                      <img src={o.imageUrl} alt="" loading="lazy" class="h-full w-full object-cover" />
                    </a>
                  ))}
                </div>
              </section>
            )}
          </div>

          {/* 하단 액션바 */}
          <div class="fixed inset-x-0 bottom-0 z-30 border-t border-neutral-200 bg-neutral-0 p-4">
            <div class="mx-auto max-w-md">
              <a href="/app/chats" class="flex h-[52px] w-full items-center justify-center rounded-md bg-primary text-body-1 text-neutral-0">스마트 문의하기</a>
            </div>
          </div>

          <script is:inline>
            document.getElementById('share-btn')?.addEventListener('click', async () => {
              const data = { title: document.title, url: location.href };
              try {
                if (navigator.share) await navigator.share(data);
                else if (navigator.clipboard) await navigator.clipboard.writeText(location.href);
              } catch {
                /* 사용자 취소 무시 */
              }
            });
          </script>
        </>
      )
    }
  </body>
</html>
