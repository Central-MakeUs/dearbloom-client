---
import AppShellLayout from '@/layouts/AppShellLayout.astro';
const { slug } = Astro.params;

export function getStaticPaths() {
  return [];
}

// TODO: 실제 API 연동. 지금은 슬러그에 상관 없이 목업 데이터.
const product = {
  id: slug ?? 'snap-1',
  title: '벚꽃엔딩',
  artist: '하늘 스튜디오',
  artistId: 'artist-1',
  artistLocation: '서울 강남',
  price: 150_000,
  description: '봄의 캠퍼스에서 담는 벚꽃 스냅. 자연스러운 미소와 함께 특별한 순간을 기록해요.\n\n• 촬영 시간: 약 90분\n• 원본: 60장 이상\n• 보정본: 15장\n• 촬영 지역: 서울/경기 (그 외 협의)',
  tags: ['졸업스냅', '봄', '캠퍼스'],
  images: 4,
};
---
<AppShellLayout title={product.title}>
  <div class="mx-auto max-w-md pb-32">
    <div class="relative aspect-square bg-gradient-to-br from-primary-100 to-primary-300">
      <a href="/snaps" class="absolute left-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-neutral-0/85 text-neutral-950 backdrop-blur" aria-label="뒤로">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </a>
      <div class="absolute bottom-4 right-4 rounded-full bg-neutral-950/60 px-2 py-0.5 text-caption-3 text-neutral-0">
        1 / {product.images}
      </div>
    </div>

    <div class="px-4 pt-4">
      <div class="mb-2 flex flex-wrap gap-1">
        {product.tags.map((t) => (
          <span class="rounded-md bg-primary-100 px-2 py-0.5 text-caption-2 text-primary-700">{t}</span>
        ))}
      </div>
      <h1 class="text-head-1 text-neutral-950">{product.title}</h1>
      <p class="mt-2 text-body-1 text-neutral-950">{product.price.toLocaleString()}원~</p>

      <a href={`/artists/${product.artistId}`} class="mt-4 flex items-center gap-3 rounded-lg bg-neutral-0 p-3">
        <div class="h-12 w-12 shrink-0 rounded-full bg-gradient-to-br from-primary-200 to-primary-400"></div>
        <div class="flex-1">
          <div class="text-body-3 text-neutral-950">{product.artist}</div>
          <div class="text-caption-2 text-neutral-600">{product.artistLocation}</div>
        </div>
        <span class="text-caption-1 text-primary">작가 보기 →</span>
      </a>
    </div>

    <section class="mt-6 border-t border-neutral-200 bg-neutral-0 px-4 py-4">
      <h2 class="mb-2 text-head-2 text-neutral-950">작품 소개</h2>
      <p class="whitespace-pre-line text-body-4 text-neutral-800">{product.description}</p>
    </section>

    <section class="mt-3 border-y border-neutral-200 bg-neutral-0 px-4 py-4">
      <div class="mb-2 flex items-center justify-between">
        <h2 class="text-head-2 text-neutral-950">Q&A</h2>
        <span class="text-caption-1 text-neutral-500">0</span>
      </div>
      <p class="text-body-5 text-neutral-500">아직 등록된 질문이 없어요.</p>
    </section>

    <section class="mt-3 border-b border-neutral-200 bg-neutral-0 px-4 py-4">
      <div class="mb-2 flex items-center justify-between">
        <h2 class="text-head-2 text-neutral-950">후기</h2>
        <span class="text-caption-1 text-neutral-500">0</span>
      </div>
      <p class="text-body-5 text-neutral-500">아직 등록된 후기가 없어요.</p>
    </section>

    <div class="fixed inset-x-0 bottom-16 z-30 border-t border-neutral-200 bg-neutral-0 p-3">
      <div class="mx-auto flex max-w-md items-center gap-2">
        <button type="button" aria-label="저장" class="flex h-12 w-12 items-center justify-center rounded-full border border-neutral-300 text-neutral-800">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
          </svg>
        </button>
        <a href="/app/saved" class="flex-1 rounded-full bg-primary py-3 text-center text-body-3 text-neutral-0">
          스마트 문의하기
        </a>
      </div>
    </div>
  </div>
</AppShellLayout>
