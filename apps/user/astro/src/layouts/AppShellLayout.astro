---
import { BottomTab } from '@dearbloom/ui';

interface Props {
  title: string;
}
const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · dearBloom</title>
  </head>
  <body class="min-h-screen bg-neutral-100 pb-20 font-sans text-neutral-950">
    <slot />
    <BottomTab currentPath={currentPath} client:load />
  </body>
</html>
