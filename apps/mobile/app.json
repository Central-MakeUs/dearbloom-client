{
  "expo": {
    "name": "dearBloom",
    "slug": "dearbloom-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "dearbloom",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "kr.co.dearbloom.mobile",
