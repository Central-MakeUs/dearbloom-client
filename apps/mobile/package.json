{
  "name": "mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "dev": "expo start --clear",
    "dev:naver": "EXPO_PUBLIC_WEBVIEW_URL=https://m.naver.com expo start",
    "android": "expo run:android",
    "ios": "open -a Simulator && expo run:ios --no-build-cache --device",
    "ios:16pro": "open -a Simulator && expo run:ios --device \"iPhone 16 Pro\"",
    "ios:naver": "open -a Simulator && EXPO_PUBLIC_WEBVIEW_URL=https://m.naver.com expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "57.0.3",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "~57.0.2",
    "expo-apple-authentication": "~57.0.1",
    "expo-build-properties": "~57.0.6",
    "expo-dev-client": "~57.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@dearbloom/config": "workspace:*",
    "@types/react": "^19.2.17",
    "eslint": "^9.15.0",
    "typescript": "^6.0.3"
  }
}
