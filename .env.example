# 환경별 값 예시 — 실제 .env 는 gitignore.
# Vercel 각 프로젝트 Settings → Environment Variables 에서 관리.
#
# NEXT_PUBLIC_API_URL 예시
#   Production  → https://api.dearbloom.co.kr   (예정, 백엔드 확정 후 반영)
#   Preview     → https://dev-api.dearbloom.co.kr
#   Development → http://localhost:8080

NEXT_PUBLIC_API_URL=http://localhost:8080

# 프론트 도메인 (필요 시 참조)
#   Production  → https://dearbloom.co.kr
#   Preview     → https://dev.dearbloom.co.kr
#   Development → http://localhost:4321
NEXT_PUBLIC_ASTRO_URL=http://localhost:4321
